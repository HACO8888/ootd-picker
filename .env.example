# 複製成 .env 並填入實際值。.env 已被 .gitignore 忽略，切勿提交真實憑證。
# 本機與 production 皆使用此檔；production 請在部署平台的環境變數設定相同的 key。

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# 部署前先跑一次 migration：pnpm db:migrate
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# ── Auth.js ─────────────────────────────────────────────────────────────────
# AUTH_SECRET：用 `npx auth secret` 或 `openssl rand -base64 33` 產生。
# 更換此值會使所有已登入的 session 失效（需重新登入）。
AUTH_SECRET=

# AUTH_URL：應用的對外網址，結尾不要加斜線。
#   本機       → http://localhost:3000
#   production → https://你的正式網域
AUTH_URL=http://localhost:3000

# 反向代理 / 容器 / Serverless 部署時設為 true。
AUTH_TRUST_HOST=true

# ── Google OAuth ────────────────────────────────────────────────────────────
# Google Cloud Console → API 與服務 → 憑證 → OAuth 2.0 用戶端。
# 「授權重新導向 URI」需包含： <AUTH_URL>/api/auth/callback/google
# （本機與 production 的 URI 可並存）
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── 對外網址（OG / canonical metadata 用）────────────────────────────────────
# metadataBase 由此決定；未設時退回 http://localhost:3000。production 請填正式網域
# （結尾不要加斜線），否則社群分享預覽圖會連到不可達網址。
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── 管理員 ──────────────────────────────────────────────────────────────────
# 逗號分隔的 email 白名單；登入時命中者自動取得 admin role（bootstrap）。
ADMIN_EMAILS=
