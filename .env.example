# 複製成 .env.local 並填入實際值。切勿提交真實憑證。

# PostgreSQL 連線字串
DATABASE_URL=

# Auth.js — 用 `npx auth secret` 產生 AUTH_SECRET
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Google OAuth（Google Cloud Console → OAuth 2.0 用戶端）
# 授權重新導向 URI 需含 <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# 管理員白名單（逗號分隔）— 登入時 email 命中者自動賦予 admin role
ADMIN_EMAILS=
